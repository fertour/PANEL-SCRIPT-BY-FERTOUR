-- Safe Script Loader
local function loadScript(url)
    local ok, err = pcall(function()
        local src = game:HttpGet(url)
        local fn = assert(loadstring(src), "loadstring failed")
        fn()
    end)
    if not ok then
        Rayfield:Notify({
            Title = "Fertour HUB Error",
            Content = tostring(err),
            Duration = 6
        })
    end
end

